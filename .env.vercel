# Vercel Production Environment Variables
# Copy these to Vercel Project Settings > Environment Variables

# MongoDB Connection String (required for production)
# Get from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aqiDB?retryWrites=true

# OpenWeatherMap API Key (optional - frontend already has a key)
# Get from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here
